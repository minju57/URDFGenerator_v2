<?xml version="1.0"?>
<robot name="my_robot">
  <mujoco >
    <compiler discardvisual="false"/>
  </mujoco>
  <link name="world"/>
  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0.0 0.0 1.0" rpy="0.0000 0.0000 0.0000"/>
  </joint>
  <link name="base_link">
    <visual >
      <origin xyz="0 0 -0.5" rpy="0 0 0"/>
      <geometry >
        <cylinder radius="0.0800" length="1.0"/>
      </geometry>
      <material name="base_grey">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <inertial >
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="10.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>
  <joint name="joint_0" type="revolute">
    <parent link="base_link"/>
    <child link="link_0"/>
    <origin xyz="0.0003 0.0005 0.0" rpy="0.0000 0.0000 0.0000"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="10" velocity="1"/>
  </joint>
  <link name="link_0">
    <visual >
      <origin xyz="0.0000 0.0003 0.0003" rpy="0.0000 0.0000 0.0000"/>
      <geometry >
        <cylinder radius="0.0300" length="0.0006"/>
      </geometry>
      <material name="mat_branch_0">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <inertial >
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>
  <joint name="joint_1" type="revolute">
    <parent link="link_0"/>
    <child link="link_1"/>
    <origin xyz="0.0 0.0005 0.0006" rpy="0.0000 0.0000 0.0000"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.1416" upper="3.1416" effort="10" velocity="1"/>
  </joint>
  <link name="link_1">
    <visual >
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry >
        <sphere radius="0.02"/>
      </geometry>
      <material name="end_effector_1">
        <color rgba="1.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <inertial >
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>
</robot>